# Committed mock-only env for local smoke tests when root .env is unavailable.
# Do not use in production. Prefer your real team .env with Firebase + Neon.
DEBUG=true
DEV_MOCK_TOKEN=dev-mock-token
NEXT_PUBLIC_DEV_MOCK_TOKEN=dev-mock-token
NEXT_PUBLIC_API_URL=http://localhost:8000
DATABASE_URL=sqlite+aiosqlite:///:memory:
CORS_ORIGINS='["http://localhost:3000","http://localhost:3001"]'
