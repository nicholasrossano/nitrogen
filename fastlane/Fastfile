FastlaneCore::Globals.verbose = false

default_platform(:ios)

require "json"
require "net/http"
require "uri"

OPENAI_API_ENDPOINT = ENV["OPENAI_BASE_URL"] || "https://api.openai.com/v1/responses"
OPENAI_MODEL        = ENV["OPENAI_MODEL"] || "gpt-4.1-mini"

def safe_truncate(s, limit)
  s = s.to_s
  s.length > limit ? s[0, limit] + "…" : s
end

def http_post_openai(url, api_key, body)
  uri = URI(url)
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = uri.scheme == "https"
  http.open_timeout = 8
  http.read_timeout = 20
  req = Net::HTTP::Post.new(uri)
  req["Content-Type"]  = "application/json"
  req["Authorization"] = "Bearer #{api_key}"
  req.body = JSON.dump(body)
  res = http.request(req)
  JSON.parse(res.body) rescue nil
end

def gpt_error_summary(fn_name:, error_message:, command:, backtrace:)
  api_key = ENV["OPENAI_API_KEY"]
  return nil if api_key.nil? || api_key.empty?

  prompt = <<~TEXT
    You are an expert CI/CD release engineer for an iOS app that deploys Google Cloud Functions with gcloud.
    Analyze this failure and produce a Slack-ready summary with exactly these sections:

    Root cause:
    Fix:
    Next checks:

    Constraints: maximum 12 lines total; concrete flags, commands, or code edits only. If uncertain, list the 1–3 most likely causes.

    Context:
    Function: #{fn_name}
    Command: #{safe_truncate(command.to_s, 500)}
    Error: #{safe_truncate(error_message.to_s, 1000)}
    Backtrace: #{safe_truncate(Array(backtrace).join("\n"), 1200)}
  TEXT

  body = {
    model: OPENAI_MODEL,
    input: prompt,
    temperature: 0.2
  }

  json = http_post_openai(OPENAI_API_ENDPOINT, api_key, body)
  return nil unless json

  text = json["output_text"]
  if (text.nil? || text.empty?) && json["output"].is_a?(Array)
    chunks = json["output"].flat_map { |m| Array(m["content"]).map { |c| c.is_a?(Hash) ? c["text"] : nil } }.compact
    text = chunks.join("\n")
  end

  out = text.to_s.strip
  out.empty? ? nil : safe_truncate(out, 3500)
rescue
  nil
end

def notify_fn(fn_name:, success:, error_message: nil, command: nil, backtrace: nil)
  message =
    if success
      "Successfully deployed #{fn_name}."
    else
      analysis = gpt_error_summary(
        fn_name:       fn_name,
        error_message: error_message,
        command:       command,
        backtrace:     backtrace
      )
      if analysis
        "*Deployment of #{fn_name} failed*\n\n#{analysis}"
      else
        "Deployment of #{fn_name} failed: #{error_message}."
      end
    end

  slack(
    slack_url: "https://hooks.slack.com/services/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",
    success:   success,
    message:   message
  )
end

$last_fn_name = nil
$last_cmd = nil

def run_cmd(command, fn_name, notify: true)
  $last_fn_name = fn_name
  $last_cmd = command
  # Ensure gcloud is on PATH for Fastlane’s non-login shell (no other changes)
  sh(%Q{env PATH="$HOME/google-cloud-sdk/bin:/opt/homebrew/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/bin:/usr/local/Caskroom/google-cloud-sdk/latest/google-cloud-sdk/bin:/opt/homebrew/bin:/usr/local/bin:$PATH" #{command}})
  notify_fn(fn_name: fn_name, success: true) if notify
  $last_fn_name = nil
  $last_cmd = nil
end

