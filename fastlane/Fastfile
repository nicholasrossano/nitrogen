  lane :emulate do
    data_dir = "./emulator-data"

    pid = Process.spawn(
      "firebase emulators:start " \
      "--only functions,firestore " \
      "--import=#{data_dir} " \
      "--export-on-exit"
    )

    require "net/http"
    require "timeout"

    ui_root = URI("http://127.0.0.1:4000")
    Timeout.timeout(30) do
      loop do
        begin
          Net::HTTP.get_response(ui_root)
          break
        rescue Errno::ECONNREFUSED
          sleep 1
        end
      end
    end

    %w[
      http://127.0.0.1:4000/functions
      http://127.0.0.1:4000/firestore
    ].each { |u| system("open", u) }

    Process.wait(pid)
  end

