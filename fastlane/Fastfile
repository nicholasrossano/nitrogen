error do |lane, exception|
  fn_to_report  = $last_fn_name || "lane #{lane}"
  cmd_to_report = $last_cmd
  unless fn_to_report == "terminate_emulators" || lane.to_s == "terminate"
    notify_fn(
      fn_name:       fn_to_report,
      success:       false,
      error_message: exception.message,
      command:       cmd_to_report,
      backtrace:     exception.backtrace
    )
  end
  $last_fn_name = nil
  $last_cmd = nil
end