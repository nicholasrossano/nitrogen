# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nitrogen

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
# Optional: Model separation (defaults shown)
# OPENAI_ORCHESTRATION_MODEL=gpt-5       # Smart model for decision-making
# OPENAI_GENERATION_MODEL=gpt-4-turbo-preview  # Cheaper model for content generation

# Storage
# local  → stores uploads on disk (fine for local dev, NOT suitable for production
#           because Railway/Heroku containers have ephemeral filesystems)
# firebase → stores uploads in Firebase Storage (recommended for production)
STORAGE_TYPE=local
EXPORTS_DIR=./exports
UPLOADS_DIR=./uploads

# Firebase Auth + Storage
# FIREBASE_PROJECT_ID=your-project-id
#
# Local dev: path to downloaded service account JSON
# NITROGEN_FIREBASE_CREDENTIALS=./firebase-service-account.json
#
# Production (Railway): paste the full JSON as a single-line string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":...}
#
# Required when STORAGE_TYPE=firebase:
# FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Debug mode (enables dev-only auth bypass)
DEBUG=false

# Dev-only mock auth token (only active when DEBUG=true)
# DEV_MOCK_TOKEN=your-dev-token-here
