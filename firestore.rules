rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow read and write access to all users under the 'users' collection
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow read access to all documents under the 'public' collection
    match /public/{document=**} {
      allow read: if true;
    }

    // Allow authenticated users to read and write their own documents under the 'private' collection
    match /private/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow read access to all documents under the 'topics' collection for authenticated users
    match /topics/{topicId} {
      allow read: if request.auth != null;
    }

    // Temporary catch-all rule for debugging - Allow authenticated users to read and write any document
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
