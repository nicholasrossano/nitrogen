    "docx-preview": "^0.3.7",
    "dompurify": "^3.3.3",
    "firebase": "^12.11.0",
    "katex": "^0.16.40",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.323.0",
    "next": "^14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
