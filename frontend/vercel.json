{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/_mintlify/:path*",
      "destination": "https://nitrogenai.mintlify.app/_mintlify/:path*"
    },
    {
      "source": "/api/request",
      "destination": "https://nitrogenai.mintlify.app/_mintlify/api/request"
    },
    {
      "source": "/docs",
      "destination": "https://nitrogenai.mintlify.app/"
    },
    {
      "source": "/docs/:match*",
      "destination": "https://nitrogenai.mintlify.app/:match*"
    },
    {
      "source": "/mintlify-assets/:path+",
      "destination": "https://nitrogenai.mintlify.app/mintlify-assets/:path+"
    }
  ]
}
