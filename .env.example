# =============================================================
# NITROGEN — Single .env (copy this to .env and fill in values)
# Both backend/.env and frontend/.env.local are symlinks to .env.
# Edit ONLY .env — both services read from it automatically.
#
# Setup (first time only — then keep your real .env; never commit it):
#   cp .env.example .env   # fill DATABASE_URL, OPENAI_API_KEY, and Firebase vars
#   bash scripts/worktree_setup.sh
#   bash scripts/check_dev_env.sh
#   bash scripts/dev_daemon.sh start
#
# Cloud agents: add the same keys as Cursor secrets, or set NITROGEN_ENV_FILE to a
# mounted .env path. Or add VERCEL_TOKEN + VERCEL_ORG_ID + VERCEL_PROJECT_ID to
# auto-pull from Vercel (dashboard env does not reach cloud VMs automatically).
# Run `bash scripts/dev_daemon.sh start` (persistent tmux stack).
# =============================================================

# ── Backend ───────────────────────────────────────────────────

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nitrogen

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Storage (local | firebase)
STORAGE_TYPE=local
EXPORTS_DIR=./exports
FIREBASE_STORAGE_BUCKET=

# Firebase Auth (required — local dev and production)
FIREBASE_PROJECT_ID=
NITROGEN_FIREBASE_CREDENTIALS=
# Or inline JSON for cloud hosts: FIREBASE_SERVICE_ACCOUNT_JSON=

# PVWatts / NREL (optional — solar production estimates)
PVWATTS_API_KEY=

# IATI API (optional — external aid/activity data)
IATI_API_KEY=

# World Bank APIs (optional overrides)
WORLDBANK_API_BASE=https://api.worldbank.org/v2
WORLDBANK_SEARCH_BASE=https://search.worldbank.org/api/v2

# App
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Google Drive OAuth (backend — optional, for Drive import feature)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/google/callback
FRONTEND_URL=http://localhost:3000

# Billing (optional — Stripe)
BILLING_TESTING_MODE=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# Deprecated — legacy two-tier price IDs (still honored by webhooks)
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Free trial defaults
TRIAL_MESSAGE_LIMIT=10
TRIAL_COST_LIMIT_USD=1.0

# Access code (optional — upgrades trial to subscription-equivalent budget)
ACCESS_CODE=

# Usage cap in USD per billing period (single individual plan)
SUBSCRIPTION_USAGE_LIMIT_USD=20.0
# Deprecated aliases
STARTER_USAGE_LIMIT_USD=14.0
PRO_USAGE_LIMIT_USD=42.0

# OpenRouter (platform LLM routing — required for non-BYOK users)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Fernet key for encrypting BYOK API keys at rest (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
API_KEY_ENCRYPTION_KEY=

# ── Frontend (NEXT_PUBLIC_ vars exposed to browser) ──────────

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ACCESS_CODE=

# Firebase (frontend — required; Firebase Console → Project Settings → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google Drive + Picker (frontend — optional, for Drive import feature)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_PROJECT_NUMBER=
NEXT_PUBLIC_GOOGLE_API_KEY=

# Stripe + billing (frontend, optional)
NEXT_PUBLIC_BILLING_ENABLED=false
NEXT_PUBLIC_STRIPE_PRICE_ID=
NEXT_PUBLIC_SUBSCRIPTION_PRICE_LABEL=$20
NEXT_PUBLIC_SUBSCRIPTION_USAGE_CAP_LABEL=$20
# Deprecated
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
