# =============================================================
# NITROGEN — Single .env (copy this to .env and fill in values)
# Both backend/.env and frontend/.env.local are symlinks to .env.
# Edit ONLY .env — both services read from it automatically.
#
# Setup:
#   cp .env.example .env
#   ln -sf ../.env backend/.env
#   ln -sf ../.env frontend/.env.local
# =============================================================

# ── Backend ───────────────────────────────────────────────────

# Database (PostgreSQL with pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nitrogen

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Storage (local | firebase)
STORAGE_TYPE=local
EXPORTS_DIR=./exports
FIREBASE_STORAGE_BUCKET=

# Firebase Auth (backend — leave blank for mock auth in dev)
FIREBASE_PROJECT_ID=
NITROGEN_FIREBASE_CREDENTIALS=

# PVWatts / NREL (optional — solar production estimates)
PVWATTS_API_KEY=

# App
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Google Drive OAuth (backend — optional, for Drive import feature)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/google/callback
FRONTEND_URL=http://localhost:3000

# Billing (optional — Stripe)
BILLING_TESTING_MODE=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Free trial defaults
TRIAL_MESSAGE_LIMIT=10
TRIAL_COST_LIMIT_USD=1.0

# Access code (optional — upgrades trial to Starter-equivalent)
ACCESS_CODE=

# Usage limits in USD per billing period
STARTER_USAGE_LIMIT_USD=14.0
PRO_USAGE_LIMIT_USD=42.0

# Fernet key for encrypting BYOK API keys at rest (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
API_KEY_ENCRYPTION_KEY=

# ── Frontend (NEXT_PUBLIC_ vars exposed to browser) ──────────

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ACCESS_CODE=

# Firebase (frontend — get from Firebase Console → Project Settings → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Google Drive + Picker (frontend — optional, for Drive import feature)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_PROJECT_NUMBER=
NEXT_PUBLIC_GOOGLE_API_KEY=

# Stripe (frontend, optional)
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
