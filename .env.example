# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nitrogen
OPENAI_API_KEY=sk-your-openai-api-key
STORAGE_TYPE=local
EXPORTS_DIR=./exports

# Firebase (optional for MVP - can use mock auth)
FIREBASE_PROJECT_ID=nitrogen-ai
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=nitrogen-ai.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=nitrogen-ai
