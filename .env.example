# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nitrogen
OPENAI_API_KEY=sk-your-openai-api-key
STORAGE_TYPE=local
EXPORTS_DIR=./exports
DEBUG=false

# Dev-only mock auth token (only active when DEBUG=true)
# DEV_MOCK_TOKEN=your-dev-token-here

# Firebase Auth (backend)
FIREBASE_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# Frontend (NEXT_PUBLIC_ vars are exposed to the browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ACCESS_CODE=your-access-code
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Production URLs (update when deploying)
# NEXT_PUBLIC_API_URL=https://api.the-nitrogen.ai
# CORS_ORIGINS=["https://the-nitrogen.ai","https://www.the-nitrogen.ai"]
